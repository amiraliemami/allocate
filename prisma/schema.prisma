generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────

enum Role {
  DS
  DE
  FSE
  PM
}

enum Level {
  Intern
  I
  II
  III
  IV
  AD
  Director
}

enum Region {
  Global
  IND
  WNA
  ESA
  SEA
}

enum TeammateStatus {
  Active
  Alumni
}

enum Pillar {
  Products
  Services
  Advisory
  Admin
}

enum BillingRate {
  Internal
  L1
  Fractional
  CoImpact
  Standard
}

enum ProjectStatus {
  Upcoming
  Active
  Paused
  Archived
  Completed
}

// ─── Models ───────────────────────────────────────────────

model Teammate {
  id     String          @id @default(cuid())
  name   String
  email  String?         @unique
  role   Role?
  level  Level?
  region Region?
  status TeammateStatus  @default(Active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledProjects Project[]
  allocations Allocation[]

  @@index([status])
  @@map("teammates")
}

model Project {
  id                    String         @id @default(cuid())
  name                  String
  pillar                Pillar?
  region                Region?
  billingRate           BillingRate?
  status                ProjectStatus  @default(Upcoming)
  conversionProbability Int?
  billable              Boolean        @default(false)
  unit4Code             String?
  startDate             DateTime?      @db.Date
  endDate               DateTime?      @db.Date
  blurb                 String?

  leadId String?
  lead   Teammate? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocations Allocation[]

  @@index([status])
  @@index([leadId])
  @@map("projects")
}

model Allocation {
  id         String   @id @default(cuid())
  teammateId String
  projectId  String
  weekStart  DateTime @db.Date
  fraction   Int
  isHidden   Boolean  @default(false)

  teammate Teammate @relation(fields: [teammateId], references: [id], onDelete: Restrict)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teammateId, projectId, weekStart])
  @@index([teammateId])
  @@index([projectId])
  @@index([weekStart])
  @@map("allocations")
}
