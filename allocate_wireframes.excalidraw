      "seed": 1695959007,
      "version": 601,
      "versionNonce": 2056951921,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775518700117,
      "link": null,
      "locked": false,
      "text": "Implementation notes:\n- Table above gives fields and possible values. Name is freetext, others are Enums\n- View should be after a groupby on Status, i.e. all \"Active\", then \"Alumnus\" under \"Alumni\" subtitle\n- Top row should be an add new option where values are filled inplace like in google sheets (no popups)\n- All values of all rows should be editable on hover and should autosave",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Implementation notes:\n- Table above gives fields and possible values. Name is freetext, others are Enums\n- View should be after a groupby on Status, i.e. all \"Active\", then \"Alumnus\" under \"Alumni\" subtitle\n- Top row should be an add new option where values are filled inplace like in google sheets (no popups)\n- All values of all rows should be editable on hover and should autosave",
      "autoResize": false,
      "lineHeight": 1.25
    },
