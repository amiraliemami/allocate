    },
    {
      "id": "2XcBm70V3Ida_txdC0NPq",
      "type": "text",
      "x": -701.5829949920256,
      "y": 526.0778227829949,
      "width": 781.5513305664062,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0g",
      "roundness": null,
      "seed": 1234663729,
      "version": 489,
      "versionNonce": 1893669919,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775518633632,
      "link": null,
      "locked": false,
      "text": "Implementation notes:\n- Table above gives fields and possible values. Name is freetext, others are Enums, Lead is a foreign key to\nthe teammate table\n- View should be after a groupby on Status, i.e. all \"Pipeline\" under \"Upcoming\" subtitle, then \"Active\" under\n\"Active\" subtitle, then Inactives, then Archived then Completed.\n- Top row should be an add new option where values are filled inplace like in google sheets (no popups)\n- All values of all rows should be editable on hover and should autosave",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Implementation notes:\n- Table above gives fields and possible values. Name is freetext, others are Enums, Lead is a foreign key to the teammate table\n- View should be after a groupby on Status, i.e. all \"Pipeline\" under \"Upcoming\" subtitle, then \"Active\" under \"Active\" subtitle, then Inactives, then Archived then Completed.\n- Top row should be an add new option where values are filled inplace like in google sheets (no popups)\n- All values of all rows should be editable on hover and should autosave",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "pzkg3wY7wpr1Y9b61q5F8",
      "type": "text",
      "x": 2326.7358810554792,
      "y": 532.4070324785874,
      "width": 781.5513305664062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0gV",
